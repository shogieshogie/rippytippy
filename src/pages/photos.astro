---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoBrowser from '../components/PhotoBrowser';
import { getPhotos, getPlaces } from '../lib/photos';

const photos = getPhotos('photos', 36);
const places = getPlaces('photos');
---

<BaseLayout title="Photos — ritnoppakun">
  <h1 class="page-title">Photos</h1>
  <PhotoBrowser client:load photos={photos} places={places} />
</BaseLayout>
